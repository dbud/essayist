{
  "name": "@essayist/core",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "imports": {
    "@openrouter/agent": "npm:@openrouter/agent@^0.7.0",
    "@openrouter/sdk": "npm:@openrouter/sdk@^0.12.79",
    "@std/assert": "jsr:@std/assert@^1",
    "zod": "npm:zod@^4"
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**/*.ts",
      "deno.json"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.spec.ts"
    ]
  },
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "test:integration": "deno test -A --env integration/",
    "repl": "deno run -A --env repl.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
