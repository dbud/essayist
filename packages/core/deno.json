{
  "exports": "./mod.ts",
  "imports": {
    "@/": "./src/",
    "@openrouter/agent": "npm:@openrouter/agent@^0.7.2",
    "@openrouter/sdk": "npm:@openrouter/sdk@^0.13.21",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "zod": "npm:zod@^4.4.3"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "name": "@essayist/core",
  "publish": {
    "exclude": ["**/*_test.ts", "**/*.spec.ts"],
    "include": ["mod.ts", "src/**/*.ts", "deno.json"]
  },
  "tasks": {
    "check": "deno run -A npm:@biomejs/biome check && deno lint . && deno check",
    "test": "deno test -A --unstable-kv --coverage",
    "test:integration": "DENO_ENV=development deno test -A --env --coverage integration/ | pino-pretty --colorize --translateTime SYS:standard --ignore pid,hostname",
    "test:watch": "deno test -A --watch"
  },
  "version": "0.1.0"
}
