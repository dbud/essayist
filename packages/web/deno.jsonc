{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "types": ["vite/client"]
  },
  "exclude": ["**/_fresh/*"],
  "exports": "./main.ts",
  "imports": {
    "@/": "./",
    "@biomejs/biome": "npm:@biomejs/biome@^2.5.3",
    "@fontsource-variable/hanken-grotesk": "npm:@fontsource-variable/hanken-grotesk@^5.2.8",
    "@fontsource-variable/recursive": "npm:@fontsource-variable/recursive@^5.2.8",
    "@fontsource-variable/source-serif-4": "npm:@fontsource-variable/source-serif-4@^5.2.9",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "@lexical/code": "npm:@lexical/code@^0.46.0",
    "@lexical/extension": "npm:@lexical/extension@^0.46.0",
    "@lexical/history": "npm:@lexical/history@^0.46.0",
    "@lexical/link": "npm:@lexical/link@^0.46.0",
    "@lexical/list": "npm:@lexical/list@^0.46.0",
    "@lexical/mark": "npm:@lexical/mark@^0.46.0",
    "@lexical/markdown": "npm:@lexical/markdown@^0.46.0",
    "@lexical/react": "npm:@lexical/react@^0.46.0",
    "@lexical/rich-text": "npm:@lexical/rich-text@^0.46.0",
    "@openrouter/agent": "npm:@openrouter/agent@^0.7.2",
    "@preact/signals": "npm:@preact/signals@^2.9.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/text": "jsr:@std/text@^1.0.19",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.20",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.2",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "@types/node": "npm:@types/node@^26.1.1",
    "daisyui": "npm:daisyui@^5.6.16",
    "dompurify": "npm:dompurify@^3.4.11",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "lexical": "npm:lexical@^0.46.0",
    "lucide-preact": "npm:lucide-preact@^1.22.0",
    "marked": "npm:marked@^18.0.5",
    "node:url": "node:url",
    "preact": "npm:preact@^10.29.7",
    "react": "npm:preact@^10.29.7/compat",
    "react-dom": "npm:preact@^10.29.7/compat",
    "tailwindcss": "npm:tailwindcss@^4.3.2",
    "vite": "npm:vite@^7.1.4"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "name": "@essayist/web",
  "tasks": {
    "build": "vite build",
    "check": "deno run -A npm:@biomejs/biome check && deno lint . && deno check",
    "dev": "DENO_ENV=development vite | pino-pretty --colorize --translateTime SYS:standard --ignore pid,hostname",
    "kv:explore": "deno run -A --env-file=.env kv_explore.ts",
    "kv:wipe": "deno run -A --env-file=.env kv_wipe.ts",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "version": "0.1.0"
}
