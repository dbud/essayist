{
  "workspace": [
    "./packages/web",
    "./packages/core",
    "./packages/core/integration"
  ],
  "nodeModulesDir": "auto",
  "deploy": {
    "org": "dbud",
    "app": "essayist"
  },
  "allowScripts": {
    "allow": ["npm:@openrouter/sdk@0.12.79", "npm:fsevents@2.3.3"],
    "deny": ["npm:esbuild@0.25.12", "npm:esbuild@0.25.7", "npm:esbuild@0.27.7"]
  },
  "imports": {
    "@lexical/code": "npm:@lexical/code@^0.45.0",
    "@lexical/link": "npm:@lexical/link@^0.45.0",
    "@lexical/list": "npm:@lexical/list@^0.45.0",
    "@lexical/rich-text": "npm:@lexical/rich-text@^0.45.0",
    "husky": "npm:husky@^9.1.7",
    "pino": "npm:pino@^10.3.1",
    "pino-pretty": "npm:pino-pretty@^13.1.3"
  },
  "tasks": {
    "fmt:check": "deno lint && deno check && deno run -A npm:@biomejs/biome check",
    "fmt": "deno run -A npm:@biomejs/biome check --write"
  }
}
