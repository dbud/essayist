{
  "workspace": [
    "./packages/web",
    "./packages/core",
    "./packages/core/integration"
  ],
  "nodeModulesDir": "manual",
  "vendor": true,
  "deploy": {
    "org": "dbud",
    "app": "essayist"
  },
  "allowScripts": {
    "allow": [
      "npm:@openrouter/sdk@0.12.79",
      "npm:fsevents@2.3.3"
    ],
    "deny": [
      "npm:esbuild@0.25.12",
      "npm:esbuild@0.25.7",
      "npm:esbuild@0.27.7"
    ]
  }
}
